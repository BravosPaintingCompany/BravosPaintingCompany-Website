---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-dark text-white">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- About column -->
      <div>
        <img src="/logo-square.png" alt="Bravo's Painting Company" class="mb-4 h-20 w-20 rounded-lg bg-white p-1 object-contain" />
        <p class="mb-4 text-sm text-white/70">
          A family business with 20+ years of experience proudly serving Orange County and surrounding areas.
        </p>
        <div class="flex flex-col gap-1 text-sm text-white/60">
          <span>Licensed, Insured & Bonded</span>
          <span>Lic #1149855</span>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-white/50">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          {[
            { href: '/', label: 'Home' },
            { href: '/services', label: 'Services' },
            { href: '/gallery', label: 'Gallery' },
            { href: '/service-areas', label: 'Service Areas' },
            { href: '/contact', label: 'Contact' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-white/70 hover:text-white transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact info -->
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-white/50">Contact Us</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-center gap-2 text-white/70">
            <svg class="h-4 w-4 flex-shrink-0 text-white/40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Diego Bravo, Owner
          </li>
          <li>
            <a href="tel:+16574334791" class="flex items-center gap-2 text-white/70 hover:text-white transition-colors">
              <svg class="h-4 w-4 flex-shrink-0 text-white/40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              (657) 433-4791
            </a>
          </li>
          <li>
            <a href="mailto:info@bravospaintingcompany.com" class="flex items-center gap-2 text-white/70 hover:text-white transition-colors">
              <svg class="h-4 w-4 flex-shrink-0 text-white/40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              info@bravospaintingcompany.com
            </a>
          </li>
          <li class="flex items-center gap-2 text-white/70">
            <svg class="h-4 w-4 flex-shrink-0 text-white/40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Orange County, CA
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-white/10 pt-6 text-center text-xs text-white/40">
      &copy; {currentYear} Bravo's Painting Company. All rights reserved. Lic #1149855
    </div>
  </div>
</footer>
