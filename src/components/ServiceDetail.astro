---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  features: string[];
  metaDescription: string;
}

const { title, description, features, metaDescription } = Astro.props;
---

<BaseLayout title={`${title} | Bravo's Painting Company`} description={metaDescription}>
  <section class="bg-brand py-16 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a href="/services" class="mb-4 inline-flex items-center text-sm text-white/70 hover:text-white">
        <svg class="mr-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Back to Services
      </a>
      <h1 class="text-4xl font-extrabold">{title}</h1>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3">
          <p class="mb-8 text-lg text-gray-600">{description}</p>

          <h2 class="mb-4 text-2xl font-bold text-gray-900">What's Included</h2>
          <ul class="mb-8 space-y-3">
            {features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">{feature}</span>
              </li>
            ))}
          </ul>

          <slot />
        </div>

        <div class="lg:col-span-2">
          <div class="sticky top-24 rounded-xl border border-gray-200 bg-gray-50 p-6">
            <h3 class="mb-2 text-xl font-bold text-gray-900">Request an Estimate</h3>
            <p class="mb-6 text-sm text-gray-600">
              Get a free, no-obligation quote for your {title.toLowerCase()} project.
            </p>
            <a
              href="/contact"
              class="block w-full rounded-lg bg-brand px-6 py-3 text-center font-semibold text-white transition-colors hover:bg-brand-light"
            >
              Get Free Estimate
            </a>
            <div class="mt-6 flex flex-col gap-3 text-sm text-gray-600">
              <div class="flex items-center gap-2">
                <svg class="h-4 w-4 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                <a href="tel:+16574334791" class="hover:text-brand">(657) 433-4791</a>
              </div>
              <div class="flex items-center gap-2">
                <svg class="h-4 w-4 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                <span>Licensed, Insured & Bonded</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
