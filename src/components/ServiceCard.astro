---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  image?: string;
  imageAlt?: string;
}

const { title, description, href, icon, image, imageAlt } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm transition-all hover:-translate-y-1 hover:border-brand/30 hover:shadow-lg"
>
  {image && (
    <div class="overflow-hidden">
      <img
        src={image}
        alt={imageAlt ?? title}
        class="aspect-[16/10] w-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </div>
  )}
  <div class="flex flex-1 flex-col p-6">
    <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-brand/10 text-2xl text-brand transition-colors group-hover:bg-brand group-hover:text-white">
      <Fragment set:html={icon} />
    </div>
    <h3 class="mb-2 text-lg font-bold text-gray-900">{title}</h3>
    <p class="flex-1 text-sm text-gray-600">{description}</p>
    <span class="mt-4 inline-flex items-center text-sm font-semibold text-brand group-hover:underline">
      Learn More
      <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  </div>
</a>
