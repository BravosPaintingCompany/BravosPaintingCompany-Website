---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us | Bravo's Painting Company" description="Get a free painting estimate in Orange County. Contact Bravo's Painting Company for interior, exterior, drywall, and cabinet painting services.">
  <section class="bg-brand py-16 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold">Contact Us</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/80">
        Ready to get started? Fill out the form below for a free, no-obligation estimate.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">

        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <h2 class="mb-6 text-2xl font-bold text-gray-900">Request a Free Estimate</h2>
          <form
            name="estimate"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-5"
            autocomplete="on"
          >
            <input type="hidden" name="form-name" value="estimate" />
            {/* Honeypot trap - bots fill this in, humans don't see it */}
            <p class="hidden" aria-hidden="true" style="display:none!important;position:absolute;left:-9999px;">
              <label>Leave this blank: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
            </p>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label for="name" class="mb-1 block text-sm font-medium text-gray-700">Full Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
                  placeholder="John Smith"
                />
              </div>
              <div>
                <label for="phone" class="mb-1 block text-sm font-medium text-gray-700">Phone Number *</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
                  placeholder="(714) 555-0123"
                />
              </div>
            </div>

            <div>
              <label for="email" class="mb-1 block text-sm font-medium text-gray-700">Email Address *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
                placeholder="john@example.com"
              />
            </div>

            <div>
              <label for="service" class="mb-1 block text-sm font-medium text-gray-700">Service Needed</label>
              <select
                id="service"
                name="service"
                class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
              >
                <option value="">Select a service...</option>
                <option value="interior">Interior Painting</option>
                <option value="exterior">Exterior Painting</option>
                <option value="drywall">Drywall Repair</option>
                <option value="cabinetry">Cabinetry</option>
                <option value="residential">Residential</option>
                <option value="commercial">Commercial</option>
                <option value="other">Other / Not Sure</option>
              </select>
            </div>

            <div>
              <label for="message" class="mb-1 block text-sm font-medium text-gray-700">Project Details</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
                placeholder="Tell us about your project: what you'd like painted, approximate size, timeline, etc."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full rounded-lg bg-brand px-8 py-4 font-bold text-white shadow-sm transition-colors hover:bg-brand-light"
            >
              Send My Request
            </button>
          </form>
        </div>

        <!-- Business Info -->
        <div class="lg:col-span-2">
          <div class="sticky top-24 space-y-6">
            <div class="rounded-xl border border-gray-200 bg-gray-50 p-6">
              <h3 class="mb-4 text-lg font-bold text-gray-900">Contact Information</h3>
              <ul class="space-y-4">
                <li class="flex items-start gap-3">
                  <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  <div>
                    <p class="font-semibold text-gray-900">Diego Bravo</p>
                    <p class="text-sm text-gray-500">Owner & Operator</p>
                  </div>
                </li>
                <li class="flex items-center gap-3">
                  <svg class="h-5 w-5 flex-shrink-0 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <a href="tel:+16574334791" class="font-semibold text-gray-900 hover:text-brand">(657) 433-4791</a>
                </li>
                <li class="flex items-center gap-3">
                  <svg class="h-5 w-5 flex-shrink-0 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <a href="mailto:info@bravospaintingcompany.com" class="font-semibold text-gray-900 hover:text-brand break-all">
                    info@bravospaintingcompany.com
                  </a>
                </li>
                <li class="flex items-center gap-3">
                  <svg class="h-5 w-5 flex-shrink-0 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span class="text-gray-700">Orange County, CA &amp; Surrounding Areas</span>
                </li>
              </ul>
            </div>

            <div class="rounded-xl border border-brand/20 bg-brand/5 p-6">
              <h3 class="mb-3 text-lg font-bold text-gray-900">Why Choose Us?</h3>
              <ul class="space-y-2 text-sm text-gray-700">
                <li class="flex items-center gap-2">
                  <svg class="h-4 w-4 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  20+ years of experience
                </li>
                <li class="flex items-center gap-2">
                  <svg class="h-4 w-4 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Licensed, Insured & Bonded · Lic #1149855
                </li>
                <li class="flex items-center gap-2">
                  <svg class="h-4 w-4 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Free, no-obligation estimates
                </li>
                <li class="flex items-center gap-2">
                  <svg class="h-4 w-4 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  Premium Sherwin-Williams & Dunn-Edwards paints
                </li>
                <li class="flex items-center gap-2">
                  <svg class="h-4 w-4 text-brand" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  100% satisfaction guaranteed
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
