---
import BaseLayout from '../layouts/BaseLayout.astro';

const reviews = [
  {
    name: 'Maria G.',
    location: 'Irvine, CA',
    rating: 5,
    text: "Diego and his crew did an amazing job on our entire home's interior. They were professional, on time, and the quality of work was outstanding. The colors came out exactly as we envisioned. We will definitely be calling Bravo's Painting again!",
    service: 'Interior Painting',
  },
  {
    name: 'Robert T.',
    location: 'Newport Beach, CA',
    rating: 5,
    text: "I hired Bravo's Painting to repaint the exterior of my home and couldn't be happier. They prepped everything thoroughly, the paint looks flawless, and they finished ahead of schedule. My neighbors keep asking who did the work!",
    service: 'Exterior Painting',
  },
  {
    name: 'Jennifer L.',
    location: 'Mission Viejo, CA',
    rating: 5,
    text: "Our kitchen cabinets look like they came straight from a showroom. Diego explained the whole process, matched the color perfectly, and the finish is super smooth. Such a transformation, way better than replacing them. Highly recommend!",
    service: 'Cabinetry',
  },
];
---

<BaseLayout title="Reviews | Bravo's Painting Company" description="Read what Orange County homeowners and businesses say about Bravo's Painting Company.">
  <section class="bg-brand py-16 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold">Customer Reviews</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/80">
        Don't take our word for it. Here's what our customers have to say.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-3">
        {reviews.map((review) => (
          <div class="flex flex-col rounded-xl border border-gray-100 bg-white p-8 shadow-sm">
            <div class="mb-4 flex gap-1">
              {Array.from({ length: review.rating }).map(() => (
                <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="mb-6 flex-1 text-gray-600 italic">"{review.text}"</p>
            <div class="border-t border-gray-100 pt-4">
              <p class="font-bold text-gray-900">{review.name}</p>
              <p class="text-sm text-gray-500">{review.location}</p>
              <span class="mt-2 inline-block rounded-full bg-brand/10 px-3 py-1 text-xs font-medium text-brand">
                {review.service}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-brand py-16 text-white">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 text-3xl font-bold">Ready to Be Our Next Happy Customer?</h2>
      <p class="mx-auto mb-8 max-w-xl text-white/80">
        Get a free estimate today and experience the Bravo's Painting difference.
      </p>
      <a href="/contact" class="inline-block rounded-lg bg-white px-8 py-4 font-bold text-brand shadow-lg transition-transform hover:-translate-y-0.5">
        Get a Free Estimate
      </a>
    </div>
  </section>
</BaseLayout>
